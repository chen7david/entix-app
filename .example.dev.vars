# Local secrets for `wrangler dev` and tooling (drizzle-kit, better-auth CLI).
# Copy: npm run dev:vars   (or: cp .example.dev.vars .dev.vars)
#
# Non-secret defaults live in wrangler.jsonc (development env vars).
# Never commit `.dev.vars`.

# --- Tooling only (drizzle-kit, migration scripts, better-auth CLI) ---
# Auto-filled by `npm run dev:vars` after first `npm run db:migrate:dev` or `npm run dev:api`
CLOUDFLARE_D1_LOCAL_DB=

# --- Required for API worker boot (secrets) ---
BETTER_AUTH_SECRET=
RESEND_API_KEY=
R2_SECRET_ACCESS_KEY=

# --- AI (required when AI_PROVIDER=deepseek in wrangler.jsonc) ---
DEEPSEEK_API_KEY=

# --- Optional local dev convenience ---
# SKIP_EMAIL_VERIFICATION=true
# SKIP_AUTH_EMAILS=true
