/**
 * Wrangler configuration optimized for local dev and secure staging/production
 * Secrets and sensitive credentials are stored in Cloudflare Workers dashboard.
 */
{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "entix-app",
    "main": "api/main.ts",
    "keep_vars": true,
    "compatibility_date": "2025-12-10",
    "compatibility_flags": ["nodejs_compat"],
    "observability": {
        "enabled": true
    },
    "env": {
        "development": {
            "triggers": {
                "crons": ["* * * * *"]
            },
            "vars": {
                "FRONTEND_URL": "http://localhost:8000",
                "CORS_ORIGINS": "http://localhost:8000",
                "CLOUDFLARE_ACCOUNT_ID": "a90c8dde75df1c270fddd905362a3f04",
                "R2_BUCKET_NAME": "entix-app-development",
                "R2_ACCESS_KEY_ID": "6406113103710221186f7c17fc8b08d2",
                "PUBLIC_CDN_URL": "https://development-cdn.entix.org",
                "AI_PROVIDER": "deepseek",
                "DEEPSEEK_MODEL": "deepseek-v4-flash",
                "GEMINI_MODEL": "gemini-2.5-flash",
                "SKIP_EMAIL_VERIFICATION": "false"
            },
            "d1_databases": [
                {
                    "binding": "DB",
                    "database_name": "entix-app-development",
                    "database_id": "12345678910",
                    "migrations_dir": "api/db/migrations"
                }
            ],
            "kv_namespaces": [
                {
                    "binding": "IDEMPOTENCY_KV",
                    "id": "local",
                    "preview_id": "local"
                }
            ],
            "queues": {
                "producers": [
                    { "binding": "QUEUE", "queue": "entix-queue-dev" },
                    { "binding": "DLQ", "queue": "entix-dlq-dev" }
                ],
                "consumers": [
                    {
                        "queue": "entix-queue-dev",
                        "dead_letter_queue": "entix-dlq-dev",
                        "max_retries": 3,
                        "max_concurrency": 1,
                        "max_batch_size": 5,
                        "max_batch_timeout": 5
                    }
                ]
            }
        },
        "local:remote": {
            "name": "entix-app-local-remote",
            "preview_urls": true,
            "triggers": {
                "crons": ["* * * * *"]
            },
            "vars": {
                "FRONTEND_URL": "http://localhost:8000",
                "CORS_ORIGINS": "http://localhost:8000",
                "CLOUDFLARE_ACCOUNT_ID": "a90c8dde75df1c270fddd905362a3f04",
                "R2_BUCKET_NAME": "entix-app-development",
                "R2_ACCESS_KEY_ID": "6406113103710221186f7c17fc8b08d2",
                "PUBLIC_CDN_URL": "https://development-cdn.entix.org",
                "AI_PROVIDER": "deepseek",
                "DEEPSEEK_MODEL": "deepseek-v4-flash",
                "GEMINI_MODEL": "gemini-2.5-flash",
                "SKIP_EMAIL_VERIFICATION": "false"
            },
            "d1_databases": [
                {
                    "binding": "DB",
                    "database_name": "entix-app-local",
                    "database_id": "602e799b-3322-45f3-b2b0-ed231cf58ba5",
                    "migrations_dir": "api/db/migrations"
                }
            ],
            "kv_namespaces": [
                {
                    "binding": "IDEMPOTENCY_KV",
                    "id": "59236dac3436497d91c827c03292b73f",
                    "preview_id": "59236dac3436497d91c827c03292b73f"
                }
            ],
            "queues": {
                "producers": [
                    { "binding": "QUEUE", "queue": "entix-app-local" },
                    { "binding": "DLQ", "queue": "entix-app-local-dlq" }
                ],
                "consumers": [
                    {
                        "queue": "entix-app-local",
                        "dead_letter_queue": "entix-app-local-dlq",
                        "max_retries": 3,
                        "max_concurrency": 1,
                        "max_batch_size": 5,
                        "max_batch_timeout": 5
                    }
                ]
            }
        },
        "staging": {
            "name": "entix-app-staging",
            "preview_urls": true,
            "triggers": {
                "crons": ["* * * * *"]
            },
            "vars": {
                "FRONTEND_URL": "https://staging.entix.org",
                "CORS_ORIGINS": "https://staging.entix.org",
                "PUBLIC_CDN_URL": "https://staging-cdn.entix.org",
                "AI_PROVIDER": "deepseek",
                "DEEPSEEK_MODEL": "deepseek-v4-flash",
                "GEMINI_MODEL": "gemini-2.5-flash",
                "SKIP_EMAIL_VERIFICATION": "false",
                "CLOUDFLARE_ACCOUNT_ID": "a90c8dde75df1c270fddd905362a3f04",
                "R2_BUCKET_NAME": "entix-app-staging",
                "R2_ACCESS_KEY_ID": "fcab42d0ac6d7603c4256e4cd26aaa75"
            },
            "assets": {
                "binding": "ASSETS",
                "directory": "./web/dist",
                "not_found_handling": "single-page-application",
                "run_worker_first": ["/api/*"]
            },
            "d1_databases": [
                {
                    "binding": "DB",
                    "database_name": "entix-app-staging",
                    "database_id": "ea4b97c4-c54b-4d92-b41d-b94cd0bad586",
                    "migrations_dir": "api/db/migrations"
                }
            ],
            "kv_namespaces": [
                {
                    "binding": "IDEMPOTENCY_KV",
                    "id": "970a9b8099d740d58cf8313ec73f6a59",
                    "preview_id": "970a9b8099d740d58cf8313ec73f6a59"
                }
            ],
            "queues": {
                "producers": [
                    { "binding": "QUEUE", "queue": "entix-queue-staging" },
                    { "binding": "DLQ", "queue": "entix-dlq-staging" }
                ],
                "consumers": [
                    {
                        "queue": "entix-queue-staging",
                        "dead_letter_queue": "entix-dlq-staging",
                        "max_retries": 3,
                        "max_concurrency": 1,
                        "max_batch_size": 5,
                        "max_batch_timeout": 5
                    }
                ]
            }
        },
        "production": {
            "name": "entix-app",
            "triggers": {
                "crons": ["* * * * *"]
            },
            "vars": {
                "FRONTEND_URL": "https://entix.org",
                "CORS_ORIGINS": "https://entix.org",
                "PUBLIC_CDN_URL": "https://cdn.entix.org",
                "AI_PROVIDER": "deepseek",
                "DEEPSEEK_MODEL": "deepseek-v4-flash",
                "GEMINI_MODEL": "gemini-2.5-flash",
                "SKIP_EMAIL_VERIFICATION": "false",
                "CLOUDFLARE_ACCOUNT_ID": "a90c8dde75df1c270fddd905362a3f04",
                "R2_BUCKET_NAME": "entix-app-production",
                "R2_ACCESS_KEY_ID": "50840d1a09535a68ffe2084a39e1742c"
            },
            "assets": {
                "binding": "ASSETS",
                "directory": "./web/dist",
                "not_found_handling": "single-page-application",
                "run_worker_first": ["/api/*"]
            },
            "d1_databases": [
                {
                    "binding": "DB",
                    "database_name": "entix-app-production",
                    "database_id": "bf5c7661-1399-454e-8bc3-78c3e39e8bfe",
                    "migrations_dir": "api/db/migrations"
                }
            ],
            "kv_namespaces": [
                {
                    "binding": "IDEMPOTENCY_KV",
                    "id": "0ee3faaba3a844b39972e94457f4d242"
                }
            ],
            "queues": {
                "producers": [
                    { "binding": "QUEUE", "queue": "entix-queue-production" },
                    { "binding": "DLQ", "queue": "entix-dlq-production" }
                ],
                "consumers": [
                    {
                        "queue": "entix-queue-production",
                        "dead_letter_queue": "entix-dlq-production",
                        "max_retries": 3,
                        "max_concurrency": 1,
                        "max_batch_size": 5,
                        "max_batch_timeout": 5
                    }
                ]
            }
        }
    }
}
