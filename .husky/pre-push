#!/bin/sh

# Run full type check before push
echo "⏳ Running project-wide type check..."
npm run typecheck
if [ $? -ne 0 ]; then
  echo "❌ Type check failed — fix errors before pushing."
  exit 1
fi
echo "✅ Type check passed."

echo "⏳ Running migration integrity gate..."
npm run check:migrations:all
if [ $? -ne 0 ]; then
  echo "❌ Migration integrity gate failed — fix migration issues before pushing."
  exit 1
fi
echo "✅ Migration integrity gate passed."
